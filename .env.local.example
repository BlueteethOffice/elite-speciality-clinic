# ══════════════════════════════════════════════════
# ELITE SPECIALITY CLINIC — Environment Variables
# ══════════════════════════════════════════════════
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# ── Firebase Configuration ──
# Get these from Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Google Places API (for real-time reviews) ──
# Get from: https://console.cloud.google.com → APIs → Places API
# Place ID for Elite Speciality Clinic: Search on https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=your_google_api_key_here
GOOGLE_PLACE_ID=your_clinic_place_id_here

# ── Email Notifications (optional) ──
# For sending email when someone books appointment
# Use Gmail App Password or SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@elitespecialityclinic.com
SMTP_PASS=your_app_password_here
NOTIFICATION_EMAIL=info@elitespecialityclinic.com
